 // Symmetric Tree

class Solution {
    public boolean is(TreeNode root1,TreeNode root2){
        if(root1==null && root2==null){
            return true;
        }
        if(root1==null || root2==null){
            return false;
        }
        
        if(root1.val!=root2.val){
            return false;
        }
        return  is(root1.left,root2.right) && is(root1.right,root2.left);
    }
    public boolean isSymmetric(TreeNode root) {
        return is(root.left,root.right);

    }
}

// Construct Binary Tree from Preorder and Inorder Traversal
 
class Solution {
    int k=0;
    public TreeNode tree(int[] preorder, int[] inorder,int i,int j,HashMap<Integer,Integer> map){
        if(i>=j) return null;
        TreeNode root=new TreeNode(preorder[k]);
        k++;
        int id=map.get(root.val);
        root.left=tree(preorder,inorder,i,id,map);
        root.right=tree(preorder,inorder,id+1,j,map);
        return root;
    }
    public TreeNode buildTree(int[] preorder, int[] inorder) {
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int i=0;i<inorder.length;i++){
            map.put(inorder[i],i);
        }
        return tree(preorder,inorder,0,preorder.length,map);
    }
}

